#!/usr/bin/env bash
# ui-verify — verify a UI flow in any running local dev server.
#
# Spawns an isolated `claude -p` subprocess with the verifier's system prompt
# inlined via --append-system-prompt and the verifier's tool allowlist enforced
# via --allowed-tools. The verifier definition lives as a sibling of this
# script (deliberately OUTSIDE ~/.claude/agents/ so it is NOT auto-discovered
# as a Claude Code subagent — invocation always goes through this script).
# Works in any context (Makefile, CI, another agent, plain shell), not just
# inside Claude Code.
#
# Usage:
#   ui-verify <url> <verification description>
#
# Examples (replace <PORT> with your project's dev-server port):
#   ui-verify http://localhost:<PORT> "page loads with an h1 reading 'Welcome'"
#   ui-verify http://localhost:<PORT> "click the submit button, type test, verify success toast appears"
#
# Output: the verifier's pass/fail markdown report on stdout.
# Exit codes: 0 on pass, 1 on fail/partial, 2 on tooling error.
set -euo pipefail

# Self-locate: find the directory this script ACTUALLY lives in, resolving
# any symlinks (e.g. ~/bin/ui-verify -> ~/mylab/ai-setup/skills/myverify-ui/ui-verify). All
# sibling files (system-prompt.md, config.sh) are looked up relative to this
# resolved directory, so renaming or moving the project folder does not break
# anything inside the script — only the symlink at ~/bin/ui-verify needs to
# be re-created.
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
    DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"

# ---- Configuration -----------------------------------------------------------
# Precedence: defaults below < values set in config.sh < UI_VERIFY_* env vars.
#
# Defaults assume the prompt is a sibling of this script. Edit config.sh to
# override values without touching this file. Env vars override at runtime.
PROMPT_FILE="$SCRIPT_DIR/system-prompt.md"
ALLOWED_TOOLS="Bash Read Write mcp__playwright__*"
MODEL="sonnet"
MCP_CONFIG_FILE="$SCRIPT_DIR/mcp.json"

if [[ -f "$SCRIPT_DIR/config.sh" ]]; then
    # shellcheck source=/dev/null
    source "$SCRIPT_DIR/config.sh"
fi

PROMPT_FILE="${UI_VERIFY_PROMPT_FILE:-$PROMPT_FILE}"
ALLOWED_TOOLS="${UI_VERIFY_ALLOWED_TOOLS:-$ALLOWED_TOOLS}"
MODEL="${UI_VERIFY_MODEL:-$MODEL}"
MCP_CONFIG_FILE="${UI_VERIFY_MCP_CONFIG:-$MCP_CONFIG_FILE}"

# Where per-run history is stored. Outside the project repo so the history is
# durable across project moves and doesn't pollute git. Override with
# UI_VERIFY_HISTORY_DIR env var or in config.sh.
HISTORY_DIR="${UI_VERIFY_HISTORY_DIR:-${HISTORY_DIR:-$HOME/.local/share/ui-verify}}"

# Optional free-form tag attached to this run's metadata. Useful for grouping
# experimental runs in the JSONL index (e.g. UI_VERIFY_NOTES="haiku trial 2").
NOTES="${UI_VERIFY_NOTES:-${NOTES:-}}"
# ------------------------------------------------------------------------------

usage() {
    cat >&2 <<'EOF'
ui-verify — verify a UI flow in a running local dev server.

Usage:
  ui-verify <url> <verification description>

Examples (replace <PORT> with your project's dev-server port):
  ui-verify http://localhost:<PORT> "page loads with an h1 reading 'Welcome'"
  ui-verify http://localhost:<PORT> "click the submit button, type test, verify success toast appears"

Exit codes: 0 = pass, 1 = fail/partial, 2 = tooling error.
EOF
    exit 2
}

if [[ $# -lt 2 ]]; then
    usage
fi

if ! command -v claude >/dev/null 2>&1; then
    echo "Error: claude CLI not found in PATH. Install Claude Code first." >&2
    exit 2
fi

if [[ ! -f "$PROMPT_FILE" ]]; then
    echo "Error: verifier system prompt not found at $PROMPT_FILE" >&2
    echo "(Override path in $SCRIPT_DIR/config.sh or via UI_VERIFY_PROMPT_FILE env var.)" >&2
    exit 2
fi

URL="$1"; shift
DESCRIPTION="$*"

# Strip YAML frontmatter (everything between the first and second --- line) and
# read the body as the system prompt. Frontmatter fields like `tools:` and
# `model:` are now informational only — the live values come from the
# configuration block above.
SYSTEM_PROMPT=$(awk 'BEGIN{state=0} /^---[[:space:]]*$/{state++; next} state>=2{print}' "$PROMPT_FILE")

if [[ -z "$SYSTEM_PROMPT" ]]; then
    echo "Error: extracted system prompt is empty — check the YAML frontmatter delimiters in $PROMPT_FILE" >&2
    exit 2
fi

USER_PROMPT="URL: ${URL}

Verify: ${DESCRIPTION}"

# ---- Run metadata (captured before invoking claude -p) ----------------------
if ! command -v jq >/dev/null 2>&1; then
    echo "Error: jq not found in PATH. Install with 'brew install jq' (macOS) or 'apt-get install jq' (Linux)." >&2
    echo "ui-verify needs jq to parse Claude's JSON output and write run history." >&2
    exit 2
fi

RUN_ID="$(date -u +%Y%m%dT%H%M%SZ)-$(printf '%04x' "$RANDOM")"
TS_START="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
SYSTEM_PROMPT_SHA="$(printf '%s' "$SYSTEM_PROMPT" | shasum -a 256 | cut -c1-8)"
CONFIG_SIGNATURE="model=$MODEL|tools=$ALLOWED_TOOLS|prompt_sha=$SYSTEM_PROMPT_SHA"
CALLER_CWD="$PWD"
CALLER_GIT_SHA="$(git -C "$CALLER_CWD" rev-parse HEAD 2>/dev/null || true)"
CALLER_GIT_DIRTY="false"
if [[ -n "$CALLER_GIT_SHA" ]] && [[ -n "$(git -C "$CALLER_CWD" status --porcelain 2>/dev/null || true)" ]]; then
    CALLER_GIT_DIRTY="true"
fi

# ---- Invoke verifier --------------------------------------------------------
# Use --output-format json so we get cost / duration / num_turns / token usage
# alongside the verifier's report in a single structured payload.
#
# The bridge ships its own mcp.json (sibling of this script) so Playwright MCP
# is only loaded inside this verifier subprocess — not in every Claude Code
# session everywhere. Other projects' main agents stay free of Playwright tool
# definitions in their context. If mcp.json is missing for any reason, the
# bridge still runs (the verifier just won't have Playwright; calls will fall
# back to scripted Bash + Write per the system prompt's existing fallback path).
MCP_FLAGS=()
if [[ -f "$MCP_CONFIG_FILE" ]]; then
    # Pre-validate that mcp.json is parseable JSON. Otherwise claude -p emits
    # a confusing "Invalid MCP configuration" error with the path mangled.
    if ! jq -e . "$MCP_CONFIG_FILE" >/dev/null 2>&1; then
        echo "Error: MCP config file at $MCP_CONFIG_FILE is not valid JSON. Run 'jq . $MCP_CONFIG_FILE' to see the parse error, then repair." >&2
        exit 2
    fi
    # The default mcp.json launches Playwright MCP via npx. If npx isn't on
    # PATH, claude -p will start fine but Playwright MCP will fail at runtime,
    # leaving the verifier without browser tools. Catch it early.
    if ! command -v npx >/dev/null 2>&1; then
        echo "Warning: npx not found in PATH but $MCP_CONFIG_FILE is present. The default mcp.json launches Playwright MCP via npx, so Playwright will fail at runtime. Install Node.js (https://nodejs.org/) to provide npx." >&2
    fi
    # --mcp-config is variadic in claude -p (consumes args until the next flag),
    # so it MUST be followed by another flag here, never by the positional
    # USER_PROMPT — otherwise the prompt gets swallowed as a second config path.
    # --strict-mcp-config disables all other MCP sources (user / project scope),
    # guaranteeing the verifier only sees what we declared in mcp.json.
    MCP_FLAGS=(--mcp-config "$MCP_CONFIG_FILE" --strict-mcp-config)
else
    echo "Warning: MCP config file not found at $MCP_CONFIG_FILE. Verifier will run without Playwright MCP and fall back to scripted Bash + Write (slower, more fragile). Restore mcp.json as a sibling of the bridge, or set UI_VERIFY_MCP_CONFIG to point at the new location." >&2
fi

set +e
# ${MCP_FLAGS[@]+"${MCP_FLAGS[@]}"} expands to nothing when the array is empty,
# avoiding "unbound variable" errors under set -u. Plain "${MCP_FLAGS[@]}" with
# an empty array tripped set -u in the missing-mcp.json path.
CLAUDE_JSON=$(claude -p \
    --dangerously-skip-permissions \
    ${MCP_FLAGS[@]+"${MCP_FLAGS[@]}"} \
    --output-format json \
    --append-system-prompt "$SYSTEM_PROMPT" \
    --allowed-tools "$ALLOWED_TOOLS" \
    --model "$MODEL" \
    "$USER_PROMPT")
CLAUDE_EXIT=$?
set -e

TS_END="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

# ---- Parse response & determine verdict -------------------------------------
if [[ -z "$CLAUDE_JSON" ]] || ! printf '%s' "$CLAUDE_JSON" | jq -e . >/dev/null 2>&1; then
    RESPONSE="(no response — claude -p exited $CLAUDE_EXIT with no parseable JSON output)"
    CLAUDE_IS_ERROR="true"
    CLAUDE_JSON_FOR_META="null"
else
    RESPONSE=$(printf '%s' "$CLAUDE_JSON" | jq -r '.result // ""')
    CLAUDE_IS_ERROR=$(printf '%s' "$CLAUDE_JSON" | jq -r '.is_error // false')
    CLAUDE_JSON_FOR_META="$CLAUDE_JSON"
fi

printf '%s\n' "$RESPONSE"

EXIT_CODE=1
VERDICT_PASS="false"
if [[ "$CLAUDE_IS_ERROR" == "true" ]] || [[ "$CLAUDE_EXIT" -ne 0 ]]; then
    EXIT_CODE=2
elif printf '%s' "$RESPONSE" | grep -qiE 'verdict:[^a-z]*\bpass\b'; then
    EXIT_CODE=0
    VERDICT_PASS="true"
fi

# ---- Write run history (best-effort; never break the verifier) --------------
{
    RUN_DIR="$HISTORY_DIR/runs/$RUN_ID"
    mkdir -p "$RUN_DIR"
    printf '%s\n' "$DESCRIPTION" > "$RUN_DIR/brief.md"
    printf '%s\n' "$RESPONSE" > "$RUN_DIR/response.md"

    META=$(jq -nc \
        --arg run_id "$RUN_ID" \
        --arg ts_start "$TS_START" \
        --arg ts_end "$TS_END" \
        --arg url "$URL" \
        --arg brief "$DESCRIPTION" \
        --argjson exit_code "$EXIT_CODE" \
        --argjson verdict_pass "$VERDICT_PASS" \
        --arg model "$MODEL" \
        --arg allowed_tools "$ALLOWED_TOOLS" \
        --arg prompt_file "$PROMPT_FILE" \
        --arg system_prompt_sha "$SYSTEM_PROMPT_SHA" \
        --arg config_signature "$CONFIG_SIGNATURE" \
        --arg caller_cwd "$CALLER_CWD" \
        --arg caller_git_sha "$CALLER_GIT_SHA" \
        --argjson caller_git_dirty "$CALLER_GIT_DIRTY" \
        --arg notes "$NOTES" \
        --argjson claude "$CLAUDE_JSON_FOR_META" \
        '{
            run_id: $run_id,
            ts_start: $ts_start,
            ts_end: $ts_end,
            url: $url,
            brief: $brief,
            exit_code: $exit_code,
            verdict_pass: $verdict_pass,
            model: $model,
            allowed_tools: $allowed_tools,
            prompt_file: $prompt_file,
            system_prompt_sha: $system_prompt_sha,
            config_signature: $config_signature,
            caller_cwd: $caller_cwd,
            caller_git_sha: (if $caller_git_sha == "" then null else $caller_git_sha end),
            caller_git_dirty: $caller_git_dirty,
            notes: $notes,
            claude: $claude
        }')

    printf '%s\n' "$META" | jq '.' > "$RUN_DIR/meta.json"
    printf '%s\n' "$META" >> "$HISTORY_DIR/runs.jsonl"
} || echo "ui-verify: warning — failed to write run history under $HISTORY_DIR" >&2

exit "$EXIT_CODE"
